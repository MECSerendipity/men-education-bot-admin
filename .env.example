# Telegram Bot
BOT_TOKEN=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Admin Web
ADMIN_WEB_LOGIN=admin
# Generate with: npx tsx admin/scripts/hash-password.ts <your-password>
ADMIN_WEB_PASSWORD_HASH=
ADMIN_WEB_JWT_SECRET=
# Optional: CORS origin for production (defaults to localhost)
# ADMIN_CORS_ORIGIN=https://admin.yourdomain.com

# WayForPay
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_SECRET_KEY=
WAYFORPAY_MERCHANT_DOMAIN=

# WayForPay Webhook
WAYFORPAY_WEBHOOK_PORT=3002
WAYFORPAY_WEBHOOK_BASE_URL=

# USDT Payment
USDT_WALLET_ADDRESS=

# ME Admin Channel (payments, partners, subscriptions)
ME_ADMIN_CHANNEL_ID=
ME_ADMIN_USDT_THREAD_ID=
ME_ADMIN_CARD_THREAD_ID=
ME_ADMIN_PARTNER_WITHDRAWAL_THREAD_ID=
ME_ADMIN_PARTNER_INACTIVE_THREAD_ID=
ME_ADMIN_JOB_MONITOR_THREAD_ID=
ME_ADMIN_JOB_MONITOR_THREAD_ID=

# Admin Telegram IDs (comma-separated) — can receive file_id from bot
ADMIN_TELEGRAM_IDS=

# Private Channels (invite links generated for users)
